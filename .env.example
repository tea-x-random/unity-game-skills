# Unity Game Skills — environment variables
#
# Copy this file to `.env` (git-ignored) for reference, but note the skills read
# from your SHELL ENVIRONMENT, not from a .env file. The reliable approach is to
# export these in your shell profile (~/.zshrc or ~/.zprofile on macOS), then open
# a new terminal / `source` it BEFORE launching Claude Code.
#
# Only set the keys for the generative skills you actually use. The core
# gameplay / graphics / UI / QA skills need no keys at all.

# 3D asset generation (unity-3d-generator) — https://platform.tripo3d.ai/
export TRIPO_API_KEY=""

# 2D image generation (unity-image-generator) — https://aistudio.google.com/apikey
export GEMINI_API_KEY=""

# Audio / voice generation (unity-audio-generator) — https://elevenlabs.io/
export ELEVENLABS_API_KEY=""
